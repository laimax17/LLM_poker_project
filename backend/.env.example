# ── OpenRouter（统一 LLM 提供者）─────────────────────────────────────────────
# 在 https://openrouter.ai/keys 创建 API Key，严禁提交到 Git
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 默认使用的模型名，支持 OpenRouter 上所有模型
# 免费模型示例：google/gemma-2-9b-it:free、meta-llama/llama-3.1-8b-instruct:free
# 付费模型示例：anthropic/claude-sonnet-4、openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemma-2-9b-it:free
